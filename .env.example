# Copy to .env and fill in:  cp .env.example .env
# Only ANTHROPIC_API_KEY is required to run the pipeline.

# Required — Claude API key for the reasoning engine (claude-sonnet-4-6).
ANTHROPIC_API_KEY=

# Optional — LangSmith tracing + evals. Leave LANGSMITH_TRACING unset/false to disable.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=opportunity-router

# Optional — POST routed-opportunity notifications to this webhook (Slack, etc.).
ROUTING_WEBHOOK_URL=

# Optional — comma-separated CORS allowlist for the API. Unset/`*` = open (fine for the demo).
ALLOWED_ORIGINS=*

# Optional — "true" populates the dashboard with the bundled sample docs on startup (handy on hosts
# that wipe in-memory state on idle). Off by default; costs LLM calls on each cold boot.
SEED_ON_STARTUP=
